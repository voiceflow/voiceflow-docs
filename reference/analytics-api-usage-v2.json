  "components": {
    "securitySchemes": {
      "auth": {
        "type": "apiKey",
        "in": "header",
        "name": "authorization",
        "description": "Voiceflow Dialog Manager API key (VF.DM)"
      }
    },
    "schemas": {
      "Query": {
        "title": "Query",
        "type": "object",
        "nullable": true,
        "description": "Types of queryable data available.\n"
      },
      "Project": {
        "title": "projectID",
        "description": "The `projectID` of your assistant.\n You can find this in your assistant's settings.",
        "type": "string",
        "required": [
          "projectID"
        ],
        "properties": {
          "projectID": {
            "type": "string",
            "example": "62912f08e83f76001b218690"
          }
        }
      },
      "BaseFilter": {
        "description": "A base filter supported by all queries that return a list",
        "type": "object",
        "properties": {
          "projectID": {
            "type": "string",
            "minLength": 1,
            "description": "The project ID for which to query usage data",
            "example": "62912f08e83f76001b218690"
          },
          "startTime": {
            "description": "A timestamp in ISO-8601 format",
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "description": "A timestamp in ISO-8601 format",
            "type": "string",
            "format": "date-time"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 500,
            "default": 100
          },
          "cursor": {
            "type": "number"
          }
        },
        "required": [
          "projectID"
        ]
      }
    }
  },
  "x-readme": {
